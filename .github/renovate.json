{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rainbowdashlabs/rainbowdashlabs"
  ],
  "baseBranchPatterns": ["main"],
  "schedule": ["on friday"],
  "packageRules": [
    {
      "groupName": "jjwt",
      "packagePatterns": [
        "^io\\.jsonwebtoken"
      ]
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
